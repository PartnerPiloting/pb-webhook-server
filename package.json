{
  "name": "test-openai-3.3",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node --max-old-space-size=1024 index.js",
    "dev": "nodemon index.js",
    "dev:api": "cross-env PORT=3001 ENABLE_TOP_SCORING_LEADS=true TOP_SCORING_LEADS_DRY_RUN=true nodemon index.js",
    "dev:front": "cross-env NEXT_PUBLIC_API_BASE_URL=http://localhost:3001 npm --prefix linkedin-messaging-followup-next run dev",
    "dev:simple": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:front\"",
    "dev:reset": "node scripts/killAllNode.js || exit 0",
    "dev:auto": "powershell -ExecutionPolicy Bypass -File scripts/Start-Dev.ps1",
    "local": "node bootstrap-local-env.js",
    "env:fetch": "node bootstrap-local-env.js",
    "env:check": "node -e \"require('dotenv').config(); console.log('Env vars loaded:', Object.keys(process.env).filter(k => !k.startsWith('npm_') && !k.startsWith('NODE_')).length)\"",
    "lh:crawl": "node scripts/crawlLhManual.js",
    "taxonomy:build": "node scripts/buildManualTaxonomy.js",
    "smoke:help": "cross-env BASE_URL=http://localhost:3001 node scripts/smokeHelp.js",
    "smoke:help:prod": "cross-env BASE_URL=https://pb-webhook-server.onrender.com node scripts/smokeHelp.js",
    "smoke:help:staging": "cross-env BASE_URL=https://pb-webhook-server-staging.onrender.com node scripts/smokeHelp.js",
    "smoke:apify:inline": "node scripts/smokeApifyInline.js",
    "smoke:apify:inline:staging": "cross-env BASE_URL=https://pb-webhook-server-staging.onrender.com node scripts/smokeApifyInline.js",
    "smoke:apify:process": "node scripts/smokeApifyProcessClient.js",
    "smoke:apify:process:staging": "cross-env BASE_URL=https://pb-webhook-server-staging.onrender.com node scripts/smokeApifyProcessClient.js",
    "cron:harvest:level2": "node scripts/apify-harvest-level2/index.js",
    "cron:post-score:level2": "node scripts/post-score-level2/index.js",
    "apify:runs:staging": "cross-env BASE_URL=https://pb-webhook-server-staging.onrender.com node scripts/showRuns.js",
    "ports:check": "node scripts/killPorts.js 3000 3001",
    "ports:free": "node scripts/killPorts.js --kill 3000 3001",
    "doc-env-vars": "node scripts/document-env-vars.js",
    "doc-env-vars:remote": "node scripts/scan-env-vars-remote.js",
    "doc-env-vars:real": "node scripts/scan-only-real-env-vars.js",
    "show-env-vars": "node scripts/show-env-vars.js",
    "sync-memberships": "node sync-client-memberships.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:add-to": "node tests/test-add-to-recipients.js",
    "gmail:oauth-token": "node scripts/gmail-oauth-get-refresh-token.js",
    "test:gmail-oauth": "node scripts/test-gmail-oauth-env.js",
    "gmail:send-test": "node scripts/gmail-send-test.js",
    "guest-booking:mint": "node scripts/guest-booking-mint-link.js",
    "guest-book:verify-inline": "node scripts/guest-book-inline-script-verify.js",
    "guest-book:harness": "node tests/guest-book-error.test.js && node scripts/guest-book-harness.js",
    "test:guest-book-error": "node tests/guest-book-error.test.js",
    "diagnose:oauth": "node scripts/diagnose-google-oauth-scopes.js",
    "diagnose:oauth:harness": "node scripts/oauth-diagnostic-harness.js",
    "test:cc-outreach": "node tests/corporateCaptivesOutreach.harness.js",
    "cc-outreach:audience-sample": "node scripts/cc-outreach-audience-sample.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
