    "cheerio": "1.0.0-rc.12",
    "cors": "^2.8.5",
    "date-holidays": "^3.26.11",
    "dirty-json": "^0.9.2",
    "dotenv": "^16.5.0",
    "email-reply-parser": "^2.3.5",
    "express": "^5.1.0",
    "form-data": "^4.0.0",
    "googleapis": "^169.0.0",
    "luxon": "^3.6.1",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.6",
    "openai": "^4.69.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-smartypants": "^3.0.2",
    "stripe": "^20.2.0",
    "unified": "^11.0.5",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
