{
  "manifest_version": 3,
  "name": "Wingguy (LinkedIn)",
  "version": "0.1.8",
  "description": "Wingguy — type /wg in a LinkedIn message box for a full-screen assistant that drafts your next message in your voice (auto-detecting the campaign). You click send.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://pb-webhook-server.vercel.app/*",
    "https://pb-webhook-server-staging.vercel.app/*",
    "https://pb-webhook-server.onrender.com/*",
    "https://pb-webhook-server-staging.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content-wingguy.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.linkedin.com/in/*/overlay/contact-info*"],
      "js": ["contact-visibility-spoof.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://pb-webhook-server.vercel.app/*", "https://pb-webhook-server-staging.vercel.app/*"],
      "js": ["content-portal.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
